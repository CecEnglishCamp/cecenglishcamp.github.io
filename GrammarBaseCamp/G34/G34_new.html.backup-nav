<!DOCTYPE html>
<html lang="ko">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>G34. Question Tags</title>
<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,500;1,500&family=Noto+Sans+KR:wght@300;400;700&family=Poppins:wght@400;600;700&display=swap" rel="stylesheet">
<style>
  :root{--bg:#f5f0e8;--white:#ffffff;--green-dark:#4a6741;--green-mid:#5a7a50;--green-light:#e8f0e5;--green-card:#3d5c35;--gold:#c8972a;--gold-light:#fdf3e0;--cream:#faf7f0;--brown:#6b5c3e;--brown-light:#f0e8d8;--text:#2d2d2d;--muted:#7a7a7a;--border:#ddd6c8}
  *{box-sizing:border-box;margin:0;padding:0}
  body{background:var(--bg);color:var(--text);font-family:'Noto Sans KR',sans-serif;line-height:1.7;padding-bottom:80px}
  .lesson-header{background:#0a1628;padding:36px 24px 32px;text-align:center}
  .gbc-badge{display:inline-block;border:1px solid rgba(0,242,255,0.5);color:rgba(0,242,255,0.8);font-family:'Poppins',sans-serif;font-size:11px;letter-spacing:2px;padding:4px 14px;border-radius:20px;margin-bottom:16px}
  .lesson-num-title{font-family:'Poppins',sans-serif;font-size:15px;font-weight:400;color:rgba(255,255,255,0.6);margin-bottom:6px}
  .lesson-main-title{font-family:'Cormorant Garamond',serif;font-style:italic;font-size:44px;font-weight:500;color:#00f2ff;line-height:1.15;margin-bottom:10px}
  .lesson-sub{font-size:14px;color:rgba(255,255,255,0.5)}
  .toc{background:var(--green-dark);padding:12px 20px;display:flex;gap:8px;flex-wrap:wrap;justify-content:center}
  .toc a{font-size:12px;padding:4px 12px;border-radius:20px;border:1px solid rgba(255,255,255,0.2);color:rgba(255,255,255,0.75);text-decoration:none}
  .toc a:hover{background:rgba(255,255,255,0.1);color:#fff}
  .content{max-width:740px;margin:0 auto;padding:0 20px}
  .section{margin-top:28px;background:var(--white);border-radius:16px;overflow:hidden;border:1px solid var(--border)}
  .section-header{display:flex;align-items:center;gap:12px;padding:14px 20px;border-bottom:1px solid var(--border)}
  .section-num{width:28px;height:28px;border-radius:8px;display:flex;align-items:center;justify-content:center;font-family:'Poppins',sans-serif;font-size:13px;font-weight:700;flex-shrink:0;color:#fff}
  .section-title{font-size:15px;font-weight:700;color:var(--text)}
  .section-en{font-size:11px;color:var(--muted);font-family:'Poppins',sans-serif;letter-spacing:1px;margin-left:6px}
  .section-body{padding:20px}
  .key-card{background:var(--green-card);border-radius:12px;padding:20px;margin-bottom:16px}
  .key-label{font-size:11px;font-family:'Poppins',sans-serif;letter-spacing:2px;color:var(--gold);margin-bottom:10px}
  .key-text{font-family:'Cormorant Garamond',serif;font-style:italic;font-size:30px;font-weight:500;color:#fff;margin-bottom:6px}
  .key-kr{font-size:13px;color:rgba(255,255,255,0.65)}
  .concept-box{background:var(--green-light);border-radius:10px;padding:16px;margin-bottom:12px;border-left:4px solid var(--green-mid)}
  .concept-box p{font-size:14px;margin-bottom:8px}
  .concept-box p:last-child{margin-bottom:0}
  .rule-grid{display:grid;grid-template-columns:1fr 1fr;gap:10px;margin-bottom:14px}
  .rule-card{padding:14px 16px;border-radius:12px;border:1px solid var(--border)}
  .rule-label{font-size:10px;font-family:'Poppins',sans-serif;letter-spacing:1.5px;font-weight:700;margin-bottom:8px}
  .rule-example{font-family:'Poppins',sans-serif;font-size:13px}
  .rule-example strong{font-weight:700}
  .r-is{background:var(--green-light);border-color:#b8d4b0}.r-is .rule-label{color:var(--green-dark)}.r-is .rule-example strong{color:var(--green-dark)}
  .r-are{background:#e8f4e8;border-color:#a8ccaa}.r-are .rule-label{color:#3a6640}.r-are .rule-example strong{color:#3a6640}
  .r-neg{background:#fdf0e0;border-color:#e8c88a}.r-neg .rule-label{color:#8a5a1a}.r-neg .rule-example strong{color:#8a5a1a}
  .r-q{background:var(--brown-light);border-color:#d4c0a0}.r-q .rule-label{color:var(--brown)}.r-q .rule-example strong{color:var(--brown)}
  .rule-list{list-style:none;display:flex;flex-direction:column;gap:6px}
  .rule-list li{font-size:14px;padding:8px 12px;background:var(--cream);border-radius:8px;border-left:3px solid var(--green-mid)}
  .rule-list li strong{color:var(--green-dark);font-family:'Poppins',sans-serif}
  .ex-list{list-style:none;display:flex;flex-direction:column;gap:8px}
  .ex-list li{padding:12px 16px;background:var(--cream);border-radius:10px;border-left:4px solid var(--green-mid);font-size:14px}
  .ex-list li .en{color:var(--green-dark);font-weight:700;font-family:'Poppins',sans-serif}
  .ex-list li .kr{color:var(--muted);font-size:12px;display:block;margin-top:2px}
  .ex-q{border-left-color:var(--brown)!important}.ex-q .en{color:var(--brown)!important}
  .dialogue{background:var(--cream);border-radius:12px;padding:16px;margin-bottom:10px;border:1px solid var(--border)}
  .d-title{font-size:10px;font-family:'Poppins',sans-serif;letter-spacing:1.5px;color:var(--gold);font-weight:700;margin-bottom:10px}
  .d-line{font-size:14px;margin-bottom:5px}
  .d-line .sp{color:var(--green-dark);font-weight:700;margin-right:6px}
  .d-line .key{color:var(--green-dark);font-weight:700;font-family:'Poppins',sans-serif}
  .practice-item{padding:12px 16px;border-radius:10px;border:1px solid var(--border);margin-bottom:8px;font-size:14px;background:var(--cream)}
  .practice-item .original{color:var(--muted);margin-bottom:4px;font-size:13px}
  .practice-item .result{color:var(--green-dark);font-weight:700;font-family:'Poppins',sans-serif}
  .pattern-box{background:var(--gold-light);border:1px solid #e8c88a;border-radius:10px;padding:14px 16px;margin-bottom:8px}
  .pattern-box .p-label{font-size:11px;color:var(--gold);font-family:'Poppins',sans-serif;letter-spacing:1px;font-weight:700;margin-bottom:6px}
  .pattern-box .p-text{font-size:14px;color:var(--brown)}
  .pattern-box .p-text strong{color:#7a5010;font-family:'Poppins',sans-serif}
  .mistake-box{background:#fff5f5;border:1px solid #f4c0c0;border-radius:10px;padding:14px 16px;margin-bottom:8px}
  .mistake-box .wrong{color:#c0392b;font-size:13px;text-decoration:line-through;margin-bottom:4px}
  .mistake-box .right{color:var(--green-dark);font-size:14px;font-weight:700;font-family:'Poppins',sans-serif}
  .mistake-box .reason{color:var(--muted);font-size:12px;margin-top:4px}
  .tip-box{background:#e8f0ff;border:1px solid #b8c8f0;border-radius:10px;padding:14px 16px;margin-bottom:8px}
  .tip-box .tip-label{font-size:11px;color:#3050a0;font-family:'Poppins',sans-serif;letter-spacing:1px;font-weight:700;margin-bottom:6px}
  .tip-box .tip-text{font-size:14px;color:#1a2a60}
  .checklist{list-style:none;display:flex;flex-direction:column;gap:8px}
  .checklist li{display:flex;align-items:center;gap:12px;font-size:14px;padding:10px 14px;background:var(--cream);border-radius:10px;cursor:pointer}
  .chk{width:20px;height:20px;border:2px solid var(--green-mid);border-radius:6px;flex-shrink:0;display:flex;align-items:center;justify-content:center;transition:all 0.2s;background:#fff}
  .chk.on{background:var(--green-mid);border-color:var(--green-dark)}
  .chk.on::after{content:'✓';color:#fff;font-size:12px;font-weight:700}
  .footer-nav{background:var(--green-dark);display:flex;justify-content:space-between;align-items:center;padding:14px 24px;margin-top:32px}
  .fnav-btn{padding:8px 20px;border-radius:20px;font-size:13px;font-weight:700;cursor:pointer;text-decoration:none;border:none;font-family:'Poppins',sans-serif}
  .fnav-prev{background:rgba(255,255,255,0.15);color:#fff}
  .fnav-center{color:rgba(255,255,255,0.6);font-size:12px;letter-spacing:1px;font-family:'Poppins',sans-serif}
  .fnav-next{background:var(--gold);color:#000}
</style>
</head>
<body data-grammar-id="G34">

<div class="lesson-header">
  <div class="gbc-badge">CEC GRAMMAR BASECAMP</div>
  <div class="lesson-num-title">G34 · Basic Grammar</div>
  <div class="lesson-main-title">Question Tags</div>
  <div class="lesson-sub">부가 의문문 — ~지, 그렇지?</div>
</div>

<div class="toc">
  <a href="#concept">기본 개념</a>
  <a href="#grammar">문법 규칙</a>
  <a href="#positive">긍정문</a>
  <a href="#question">의문문</a>
  <a href="#dialogue">대화 흐름</a>
  <a href="#combining">문장 결합</a>
  <a href="#reallife">실생활</a>
  <a href="#patterns">패턴</a>
  <a href="#mistakes">흔한 실수</a>
  <a href="#tips">레벨업 팁</a>
  <a href="#practice">연습문제</a>
  <a href="#check">자가진단</a>
</div>

<div class="content">

  <!-- 1 -->
  <div class="section" id="s1">
    <div class="section-header">
      <div class="section-num" style="background:var(--green-dark);">1</div>
      <div><span class="section-title">기본 개념</span><span class="section-en">BASIC CONCEPT</span></div>
    </div>
    <div class="section-body">
      <div class="key-card">
        <div class="key-label">⭐ TODAY'S KEY GRAMMAR</div>
        <div class="key-text">Question Tags</div>
        <div class="key-kr">문장 끝에 짧은 질문을 붙여 확인하는 표현 — ~지, 그렇지?</div>
      </div>
      <div class="concept-box">
        <p><strong style="color:var(--green-dark)">긍정문 + 부정 태그</strong> → You're tired, <strong>aren't you?</strong> / She likes music, <strong>doesn't she?</strong></p>
        <p><strong style="color:#3a6640">부정문 + 긍정 태그</strong> → You don't like coffee, <strong>do you?</strong> / She isn't coming, <strong>is she?</strong></p>
        <p>억양에 따라 의미가 달라집니다: ↗ 진짜 궁금할 때 / ↘ 확신하며 확인할 때</p>
      </div>
      <ul class="ex-list">
        <li><span class="en">It's a beautiful day, isn't it?</span><span class="kr">아름다운 날이네요, 그렇지 않아요?</span></li>
        <li><span class="en">You don't speak German, do you?</span><span class="kr">독일어 못 하시죠, 그렇죠?</span></li>
        <li><span class="en">We should leave now, shouldn't we?</span><span class="kr">이제 가야 하지 않을까요?</span></li>
      </ul>
    </div>
  </div>

  <!-- 2 -->
  <div class="section" id="s2">
    <div class="section-header">
      <div class="section-num" style="background:#3a6640;">2</div>
      <div><span class="section-title">문법 규칙</span><span class="section-en">GRAMMAR RULES</span></div>
    </div>
    <div class="section-body">
      <div class="rule-grid">
        <div class="rule-card r-is">
          <div class="rule-label">BE 동사 · BE VERB</div>
          <div class="rule-example"><strong>You are happy, aren't you?</strong><br><span style="font-size:12px;color:var(--muted)">I'm late, aren't I? (예외)</span></div>
        </div>
        <div class="rule-card r-are">
          <div class="rule-label">조동사 · MODAL VERBS</div>
          <div class="rule-example"><strong>You can swim, can't you?</strong><br><span style="font-size:12px;color:var(--muted)">She will come, won't she?</span></div>
        </div>
        <div class="rule-card r-neg">
          <div class="rule-label">일반동사 · GENERAL VERBS</div>
          <div class="rule-example"><strong>You like coffee, don't you?</strong><br><span style="font-size:12px;color:var(--muted)">He played soccer, didn't he?</span></div>
        </div>
        <div class="rule-card r-q">
          <div class="rule-label">부정문 태그 · NEGATIVE TAGS</div>
          <div class="rule-example"><strong>부정문 → 긍정 태그</strong><br><span style="font-size:12px;color:var(--muted)">You can't drive, can you?</span></div>
        </div>
      </div>
      <ul class="rule-list">
        <li><strong>기본 원칙:</strong> 긍정문 뒤에는 부정 태그, 부정문 뒤에는 긍정 태그</li>
        <li><strong>조동사가 있으면</strong> 그 조동사를 태그에 사용</li>
        <li><strong>조동사가 없으면</strong> do/does/did 사용</li>
        <li><strong>특별한 경우:</strong> I'm late, aren't I? (amn't는 사용하지 않음)</li>
        <li><strong>주어 변환:</strong> 태그에서 주어는 반드시 대명사로 변환</li>
      </ul>
    </div>
  </div>

  <!-- 3 -->
  <div class="section" id="s3">
    <div class="section-header">
      <div class="section-num" style="background:var(--gold); color:#000;">3</div>
      <div><span class="section-title">긍정문 예시</span><span class="section-en">POSITIVE EXAMPLES</span></div>
    </div>
    <div class="section-body">
      <ul class="ex-list">
        <li><span class="en">You're tired, aren't you?</span><span class="kr">피곤하시죠, 그렇지 않나요?</span></li>
        <li><span class="en">She is a teacher, isn't she?</span><span class="kr">선생님이시죠, 그렇지 않나요?</span></li>
        <li><span class="en">They were late, weren't they?</span><span class="kr">늦었었죠, 그렇지 않나요?</span></li>
        <li><span class="en">You can swim, can't you?</span><span class="kr">수영할 수 있죠, 그렇지 않나요?</span></li>
        <li><span class="en">She will help us, won't she?</span><span class="kr">도와줄 거죠, 그렇지 않나요?</span></li>
        <li><span class="en">You like music, don't you?</span><span class="kr">음악 좋아하죠, 그렇지 않나요?</span></li>
        <li><span class="en">She speaks English, doesn't she?</span><span class="kr">영어 하죠, 그렇지 않나요?</span></li>
        <li><span class="en">We met before, didn't we?</span><span class="kr">전에 만났었죠, 그렇지 않나요?</span></li>
        <li><span class="en">I'm late, aren't I?</span><span class="kr">제가 늦었죠, 그렇지 않나요? (특별한 경우)</span></li>
        <li><span class="en">He must be tired, mustn't he?</span><span class="kr">피곤할 거죠, 그렇지 않나요?</span></li>
      </ul>
    </div>
  </div>

  <!-- 4 -->
  <div class="section" id="s4">
    <div class="section-header">
      <div class="section-num" style="background:var(--brown);">4</div>
      <div><span class="section-title">의문문 예시</span><span class="section-en">QUESTION EXAMPLES</span></div>
    </div>
    <div class="section-body">
      <ul class="ex-list">
        <li class="ex-q"><span class="en">You aren't busy, are you?</span><span class="kr">바쁘지 않으시죠, 그렇죠?</span></li>
        <li class="ex-q"><span class="en">She isn't coming, is she?</span><span class="kr">오지 않죠, 그렇죠?</span></li>
        <li class="ex-q"><span class="en">We aren't late, are we?</span><span class="kr">늦지 않았죠, 그렇죠?</span></li>
        <li class="ex-q"><span class="en">You can't drive, can you?</span><span class="kr">운전 못 하죠, 그렇죠?</span></li>
        <li class="ex-q"><span class="en">She won't mind, will she?</span><span class="kr">신경 안 쓸 거죠, 그렇죠?</span></li>
        <li class="ex-q"><span class="en">You don't like coffee, do you?</span><span class="kr">커피 안 좋아하죠, 그렇죠?</span></li>
        <li class="ex-q"><span class="en">She doesn't speak German, does she?</span><span class="kr">독일어 못 하죠, 그렇죠?</span></li>
        <li class="ex-q"><span class="en">I'm not wrong, am I?</span><span class="kr">제가 틀리지 않았죠, 그렇죠?</span></li>
      </ul>
    </div>
  </div>

  <!-- 5 -->
  <div class="section" id="s5">
    <div class="section-header">
      <div class="section-num" style="background:#5a7a50;">5</div>
      <div><span class="section-title">상황별 대화 흐름</span><span class="section-en">SITUATIONAL DIALOGUES</span></div>
    </div>
    <div class="section-body">
      <div class="dialogue">
        <div class="d-title">🏫 학교 상황 · SCHOOL</div>
        <div class="d-line"><span class="sp">A:</span> You finished your homework, <span class="key">didn't you?</span></div>
        <div class="d-line"><span class="sp">B:</span> Yes, I did it last night.</div>
        <div class="d-line"><span class="sp">A:</span> The test is tomorrow, <span class="key">isn't it?</span></div>
        <div class="d-line"><span class="sp">B:</span> I think so. You studied for it, <span class="key">didn't you?</span></div>
      </div>
      <div class="dialogue">
        <div class="d-title">💼 직장 상황 · WORK</div>
        <div class="d-line"><span class="sp">A:</span> You sent the email, <span class="key">didn't you?</span></div>
        <div class="d-line"><span class="sp">B:</span> Yes, this morning.</div>
        <div class="d-line"><span class="sp">A:</span> The meeting starts at 2, <span class="key">doesn't it?</span></div>
        <div class="d-line"><span class="sp">B:</span> That's right.</div>
      </div>
      <div class="dialogue">
        <div class="d-title">✈️ 여행 계획 · TRAVEL</div>
        <div class="d-line"><span class="sp">A:</span> We're taking the 10 AM train, <span class="key">aren't we?</span></div>
        <div class="d-line"><span class="sp">B:</span> Yes, from Central Station.</div>
        <div class="d-line"><span class="sp">A:</span> The station <span class="key">isn't</span> far, <span class="key">is it?</span></div>
        <div class="d-line"><span class="sp">B:</span> No, just 15 minutes by bus.</div>
      </div>
      <div class="dialogue">
        <div class="d-title">🍽️ 레스토랑 상황 · RESTAURANT</div>
        <div class="d-line"><span class="sp">A:</span> This restaurant is quite popular, <span class="key">isn't it?</span></div>
        <div class="d-line"><span class="sp">B:</span> Yes, we were lucky to get a table.</div>
        <div class="d-line"><span class="sp">A:</span> You don't eat seafood, <span class="key">do you?</span></div>
        <div class="d-line"><span class="sp">B:</span> Actually, I do!</div>
      </div>
      <div class="dialogue">
        <div class="d-title">🌤️ 날씨 대화 · WEATHER</div>
        <div class="d-line"><span class="sp">A:</span> It's quite cold today, <span class="key">isn't it?</span></div>
        <div class="d-line"><span class="sp">B:</span> Yes, much colder than yesterday.</div>
        <div class="d-line"><span class="sp">A:</span> You didn't bring a jacket, <span class="key">did you?</span></div>
        <div class="d-line"><span class="sp">B:</span> No, I forgot.</div>
      </div>
    </div>
  </div>

  <!-- 6 -->
  <div class="section" id="s6">
    <div class="section-header">
      <div class="section-num" style="background:var(--green-dark);">6</div>
      <div><span class="section-title">문장 결합 연습</span><span class="section-en">SENTENCE COMBINING</span></div>
    </div>
    <div class="section-body">
      <div class="practice-item">
        <div class="original">You are tired.</div>
        <div class="result">→ You are tired, aren't you?</div>
      </div>
      <div class="practice-item">
        <div class="original">She doesn't eat meat.</div>
        <div class="result">→ She doesn't eat meat, does she?</div>
      </div>
      <div class="practice-item">
        <div class="original">We met before.</div>
        <div class="result">→ We met before, didn't we?</div>
      </div>
      <div class="practice-item">
        <div class="original">He isn't busy.</div>
        <div class="result">→ He isn't busy, is he?</div>
      </div>
      <div class="practice-item">
        <div class="original">I'm late.</div>
        <div class="result">→ I'm late, aren't I?</div>
      </div>
      <div class="practice-item">
        <div class="original">She can swim.</div>
        <div class="result">→ She can swim, can't she?</div>
      </div>
      <div class="practice-item">
        <div class="original">He will help us.</div>
        <div class="result">→ He will help us, won't he?</div>
      </div>
      <div class="practice-item">
        <div class="original">You don't like spicy food.</div>
        <div class="result">→ You don't like spicy food, do you?</div>
      </div>
      <div class="practice-item">
        <div class="original">She was here yesterday.</div>
        <div class="result">→ She was here yesterday, wasn't she?</div>
      </div>
    </div>
  </div>

  <!-- 7 -->
  <div class="section" id="s7">
    <div class="section-header">
      <div class="section-num" style="background:var(--gold); color:#000;">7</div>
      <div><span class="section-title">실생활 사용 예시</span><span class="section-en">REAL-LIFE USAGE</span></div>
    </div>
    <div class="section-body">
      <ul class="ex-list">
        <li><span class="en">You received the file I sent, didn't you?</span><span class="kr">📧 이메일 확인 — 보내드린 파일 받으셨죠?</span></li>
        <li><span class="en">We're all in agreement about the proposal, aren't we?</span><span class="kr">💼 회의 중 — 제안에 모두 동의하죠?</span></li>
        <li><span class="en">She didn't call back about the interview, did she?</span><span class="kr">📞 전화 통화 — 면접 관련해서 다시 전화 안 했죠?</span></li>
        <li><span class="en">It's a beautiful day for a picnic, isn't it?</span><span class="kr">🌤️ 일상 대화 — 피크닉 하기 좋은 날이네요, 그렇죠?</span></li>
        <li><span class="en">You all understood the grammar point, didn't you?</span><span class="kr">🏫 수업 중 — 문법 포인트 모두 이해했죠?</span></li>
      </ul>
    </div>
  </div>

  <!-- 8 -->
  <div class="section" id="s8">
    <div class="section-header">
      <div class="section-num" style="background:var(--brown);">8</div>
      <div><span class="section-title">자주 쓰이는 패턴</span><span class="section-en">COMMON PATTERNS</span></div>
    </div>
    <div class="section-body">
      <div class="pattern-box">
        <div class="p-label">BE 동사 + TAG</div>
        <div class="p-text"><strong>He's here, isn't he?</strong><br><span style="font-size:13px;">She was happy, wasn't she?</span></div>
      </div>
      <div class="pattern-box">
        <div class="p-label">조동사 + TAG</div>
        <div class="p-text"><strong>She can help, can't she?</strong><br><span style="font-size:13px;">He will come, won't he?</span></div>
      </div>
      <div class="pattern-box">
        <div class="p-label">DO/DOES/DID + TAG</div>
        <div class="p-text"><strong>You like coffee, don't you?</strong><br><span style="font-size:13px;">She speaks French, doesn't she?</span></div>
      </div>
      <div class="pattern-box">
        <div class="p-label">부정문 + 긍정 TAG</div>
        <div class="p-text"><strong>They don't know, do they?</strong><br><span style="font-size:13px;">She won't mind, will she?</span></div>
      </div>
    </div>
  </div>

  <!-- 9 -->
  <div class="section" id="s9">
    <div class="section-header">
      <div class="section-num" style="background:#c0392b;">9</div>
      <div><span class="section-title">흔한 실수</span><span class="section-en">COMMON MISTAKES</span></div>
    </div>
    <div class="section-body">
      <div class="mistake-box">
        <div class="wrong">✗ You are tired, are you?</div>
        <div class="right">✓ You are tired, aren't you?</div>
        <div class="reason">긍정문 뒤에는 부정 태그 사용</div>
      </div>
      <div class="mistake-box">
        <div class="wrong">✗ She likes music, doesn't he?</div>
        <div class="right">✓ She likes music, doesn't she?</div>
        <div class="reason">태그의 주어는 주절의 주어와 일치해야 함</div>
      </div>
      <div class="mistake-box">
        <div class="wrong">✗ I'm late, amn't I?</div>
        <div class="right">✓ I'm late, aren't I?</div>
        <div class="reason">I'm의 태그는 항상 aren't I (amn't는 사용하지 않음)</div>
      </div>
      <div class="mistake-box">
        <div class="wrong">✗ You like coffee, isn't it?</div>
        <div class="right">✓ You like coffee, don't you?</div>
        <div class="reason">일반동사에는 do/does/did를 태그에 사용</div>
      </div>
    </div>
  </div>

  <!-- 10 -->
  <div class="section" id="s10">
    <div class="section-header">
      <div class="section-num" style="background:#185fa5;">10</div>
      <div><span class="section-title">레벨업 팁</span><span class="section-en">LEVEL-UP TIPS</span></div>
    </div>
    <div class="section-body">
      <div class="tip-box">
        <div class="tip-label">TIP 1 · 기본 원칙</div>
        <div class="tip-text">긍정문 → 부정 태그, 부정문 → 긍정 태그. 이 원칙만 기억하면 됩니다!</div>
      </div>
      <div class="tip-box">
        <div class="tip-label">TIP 2 · 억양의 중요성</div>
        <div class="tip-text">올라가는 억양(↗)은 진짜 궁금할 때, 내려가는 억양(↘)은 확신하며 확인할 때 사용합니다.</div>
      </div>
      <div class="tip-box">
        <div class="tip-label">TIP 3 · 대화의 윤활유</div>
        <div class="tip-text">Question tags는 영어 대화에서 상대방과의 상호작용을 자연스럽게 유도하는 중요한 도구입니다.</div>
      </div>
      <div class="tip-box">
        <div class="tip-label">TIP 4 · I'm 예외</div>
        <div class="tip-text">I'm의 태그는 항상 aren't I입니다. I'm late, aren't I?</div>
      </div>
    </div>
  </div>

  <!-- 11 -->
  <div class="section" id="s11">
    <div class="section-header">
      <div class="section-num" style="background:var(--green-dark);">11</div>
      <div><span class="section-title">연습문제</span><span class="section-en">PRACTICE EXERCISES</span></div>
    </div>
    <div class="section-body">
      <p style="font-size:13px; color:var(--muted); margin-bottom:14px;">적절한 question tag를 추가하세요.</p>
      <ul class="rule-list">
        <li>You are happy, ___? <strong style="color:var(--green-dark)">(aren't you)</strong></li>
        <li>She doesn't like coffee, ___? <strong style="color:var(--brown)">(does she)</strong></li>
        <li>They were late, ___? <strong style="color:var(--green-dark)">(weren't they)</strong></li>
        <li>He can swim, ___? <strong style="color:var(--green-dark)">(can't he)</strong></li>
        <li>You won't tell anyone, ___? <strong style="color:var(--brown)">(will you)</strong></li>
        <li>I'm right, ___? <strong style="color:var(--green-dark)">(aren't I)</strong></li>
        <li>She plays tennis, ___? <strong style="color:var(--green-dark)">(doesn't she)</strong></li>
        <li>We should leave, ___? <strong style="color:var(--green-dark)">(shouldn't we)</strong></li>
      </ul>
    </div>
  </div>

  <!-- 12 -->
  <div class="section" id="s11">
    <div class="section-header">
      <div class="section-num" style="background:var(--brown);">12</div>
      <div><span class="section-title">자가진단 체크리스트</span><span class="section-en">SELF-CHECK</span></div>
    </div>
    <div class="section-body">
      <ul class="checklist">
        <li onclick="this.querySelector('.chk').classList.toggle('on')"><div class="chk"></div> 긍정문 뒤에 부정 tag를 붙일 수 있다.</li>
        <li onclick="this.querySelector('.chk').classList.toggle('on')"><div class="chk"></div> 부정문 뒤에 긍정 tag를 붙일 수 있다.</li>
        <li onclick="this.querySelector('.chk').classList.toggle('on')"><div class="chk"></div> be동사/조동사에 맞는 tag를 만들 수 있다.</li>
        <li onclick="this.querySelector('.chk').classList.toggle('on')"><div class="chk"></div> 일반동사에 맞는 tag를 만들 수 있다.</li>
        <li onclick="this.querySelector('.chk').classList.toggle('on')"><div class="chk"></div> 대화에서 자연스럽게 사용할 수 있다.</li>
      </ul>
    </div>
  </div>

</div>

<div class="footer-nav">
  <a href="G33_new.html" class="fnav-btn fnav-prev">← G33</a>
  <span class="fnav-center">G34 · QUESTION TAGS</span>
  <a href="G35_new.html" class="fnav-btn fnav-next">G35 →</a>
</div>




<style>
.gb{position:fixed;bottom:24px;right:24px;z-index:9999;display:flex;flex-direction:column;align-items:flex-end;gap:8px;}
.gb-hint{background:#4a6741;color:#fff;font-size:12px;padding:7px 14px;border-radius:20px 20px 4px 20px;cursor:pointer;white-space:nowrap;animation:gbFloat 3s ease-in-out infinite;font-family:sans-serif;}
.gb-hint span{color:#c8e6a0;}
@keyframes gbFloat{0%,100%{transform:translateY(0);}50%{transform:translateY(-4px);}}
.gb-robo{width:56px;height:56px;border-radius:50%;background:#4a6741;border:2px solid #a8d070;cursor:pointer;overflow:hidden;display:flex;align-items:center;justify-content:center;}
.gb-robo img{width:46px;height:46px;object-fit:cover;border-radius:50%;}
.gb-panel{display:none;position:fixed;bottom:92px;right:24px;width:300px;background:#fff;border-radius:20px;border:0.5px solid #c8d8b8;box-shadow:0 4px 24px rgba(74,103,65,0.15);overflow:hidden;z-index:9998;}
.gb-head{background:#4a6741;padding:12px 16px;display:flex;align-items:center;gap:10px;}
.gb-head img{width:28px;height:28px;border-radius:50%;object-fit:cover;}
.gb-ht{font-size:13px;font-weight:700;color:#fff;font-family:sans-serif;}
.gb-hs{font-size:11px;color:#c8e6a0;font-family:sans-serif;}
.gb-close{margin-left:auto;background:none;border:none;color:#a0c080;font-size:14px;cursor:pointer;}
.gb-chat{padding:12px 14px;height:180px;overflow-y:auto;display:flex;flex-direction:column;gap:8px;background:#f8faf5;}
.gb-ai-msg{display:flex;gap:8px;align-items:flex-start;}
.gb-ai-msg img{width:22px;height:22px;border-radius:50%;object-fit:cover;flex-shrink:0;}
.gb-ai-bubble{background:#fff;border:0.5px solid #c8d8b8;border-radius:0 10px 10px 10px;padding:8px 12px;font-size:12px;color:#2d4a25;line-height:1.6;max-width:210px;white-space:pre-line;font-family:sans-serif;}
.gb-user-msg{display:flex;justify-content:flex-end;}
.gb-user-bubble{background:#4a6741;color:#fff;border-radius:10px 0 10px 10px;padding:8px 12px;font-size:12px;max-width:200px;line-height:1.5;white-space:pre-line;font-family:sans-serif;}
.gb-input-row{padding:10px 12px;border-top:0.5px solid #d0e0c0;display:flex;gap:8px;background:#fff;}
.gb-input{flex:1;padding:8px 12px;border-radius:20px;border:0.5px solid #c0d0b0;font-size:12px;font-family:sans-serif;outline:none;background:#f8faf5;}
.gb-send{width:34px;height:34px;border-radius:50%;background:#4a6741;border:none;cursor:pointer;color:#fff;font-size:14px;flex-shrink:0;}
.gb-btns{padding:10px 12px 12px;display:flex;gap:8px;background:#fff;}
.gb-btn1{flex:1;padding:9px;background:#4a6741;color:#fff;border:none;border-radius:10px;font-size:12px;font-weight:700;cursor:pointer;font-family:sans-serif;}
.gb-btn2{flex:1;padding:9px;background:#f0f8e8;border:0.5px solid #a8d070;color:#4a6741;border-radius:10px;font-size:12px;font-weight:700;cursor:pointer;font-family:sans-serif;}
</style>
<div class="gb">
  <div class="gb-hint" onclick="gbToggle()" id="gbHint">
    <span id="gbHintText">문법</span> 질문 있으세요?
  </div>
  <div class="gb-robo" onclick="gbToggle()">
    <img src="../robo_jump.gif" alt="Robo" onerror="this.src='https://pub-a418b5aad0bd4c3fb41cf7159403fc12.r2.dev/robo_jump.gif'">
  </div>
</div>
<div class="gb-panel" id="gbPanel">
  <div class="gb-head">
    <img src="../robo_jump.gif" alt="Robo" onerror="this.src='https://pub-a418b5aad0bd4c3fb41cf7159403fc12.r2.dev/robo_jump.gif'">
    <div>
      <div class="gb-ht">Grammar AI 선생님</div>
      <div class="gb-hs" id="gbSub">문법 설명 + 회화 연결</div>
    </div>
    <button class="gb-close" onclick="gbToggle()">&#10005;</button>
  </div>
  <div class="gb-chat" id="gbChat">
    <div class="gb-ai-msg">
      <img src="../robo_jump.gif" onerror="this.src='https://pub-a418b5aad0bd4c3fb41cf7159403fc12.r2.dev/robo_jump.gif'">
      <div class="gb-ai-bubble">안녕하세요! 👋 궁금한 문법 뭐든 물어보세요!</div>
    </div>
  </div>
  <div class="gb-input-row">
    <input class="gb-input" id="gbInput" type="text" placeholder="질문을 입력하세요..." onkeydown="if(event.key==='Enter')gbSend()">
    <button class="gb-send" onclick="gbSend()">→</button>
  </div>
  <div class="gb-btns">
    <button class="gb-btn1" onclick="gbAsk()">💬 Open WebUI 열기</button>
    <button class="gb-btn2" onclick="gbCamp()">🏕️ 캠프 보기</button>
  </div>
</div>
<script src="../grammar_story_map.js"></script>
<script>
(function(){
  var path=window.location.pathname;
  var m=path.match(/G(\d+)/i);
  var gid=m?'G'+('0'+m[1]).slice(-2):'G01';
  var data=(typeof GRAMMAR_STORY_MAP!=='undefined')?GRAMMAR_STORY_MAP[gid]:null;
  if(data){
    document.getElementById('gbHintText').textContent=data.title;
    document.getElementById('gbSub').textContent=gid+' — '+data.title;
    gbAddAI('안녕하세요! 👋\n'+data.title+' 궁금한 거 물어보세요!\n예: '+data.example);
  }
  var gbOpen=false;
  window.gbToggle=function(){
    gbOpen=!gbOpen;
    document.getElementById('gbPanel').style.display=gbOpen?'block':'none';
    document.getElementById('gbHint').style.opacity=gbOpen?'0':'1';
    if(gbOpen)setTimeout(function(){document.getElementById('gbInput').focus();},100);
  };
  window.gbSend=function(){
    var inp=document.getElementById('gbInput');
    var msg=inp.value.trim();
    if(!msg)return;
    gbAddUser(msg);
    inp.value='';
    setTimeout(function(){gbAddAI('좋은 질문이에요!\nOpen WebUI에서 더 자세히 답해드릴게요 😊');},500);
  };
  window.gbAsk=function(){
    var prompt=data?data.prompt:'문법 질문이 있어요!';
    navigator.clipboard.writeText(prompt).catch(function(){});
    window.open('http://localhost:3001/?models=cec_grammar','_blank');
  };
  window.gbCamp=function(){
    window.open('https://cecenglishcamp.github.io/','_blank');
  };
  window.gbAddAI=function(msg){
    var c=document.getElementById('gbChat');
    var d=document.createElement('div');
    d.className='gb-ai-msg';
    d.innerHTML='<img src="../robo_jump.gif" onerror="this.src=\'https://pub-a418b5aad0bd4c3fb41cf7159403fc12.r2.dev/robo_jump.gif\'">'
      +'<div class="gb-ai-bubble">'+msg+'</div>';
    c.appendChild(d);c.scrollTop=c.scrollHeight;
  };
  window.gbAddUser=function(msg){
    var c=document.getElementById('gbChat');
    var d=document.createElement('div');
    d.className='gb-user-msg';
    d.innerHTML='<div class="gb-user-bubble">'+msg+'</div>';
    c.appendChild(d);c.scrollTop=c.scrollHeight;
  };
  setTimeout(function(){
    var h=document.getElementById('gbHint');
    if(h){h.style.background='#a8d070';h.style.color='#2d4a25';
      setTimeout(function(){h.style.background='#4a6741';h.style.color='#fff';},2000);}
  },5000);
})();
</script>
</body>
</html>