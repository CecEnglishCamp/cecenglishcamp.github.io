<!DOCTYPE html>
<html lang="ko">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>G67. Modals of Deduction</title>
<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,500;1,500&family=Noto+Sans+KR:wght@300;400;700&family=Poppins:wght@400;600;700&display=swap" rel="stylesheet">
<style>
  :root{--bg:#f5f0e8;--white:#ffffff;--green-dark:#4a6741;--green-mid:#5a7a50;--green-light:#e8f0e5;--green-card:#3d5c35;--gold:#c8972a;--gold-light:#fdf3e0;--cream:#faf7f0;--brown:#6b5c3e;--brown-light:#f0e8d8;--text:#2d2d2d;--muted:#7a7a7a;--border:#ddd6c8}
  *{box-sizing:border-box;margin:0;padding:0}body{background:var(--bg);color:var(--text);font-family:'Noto Sans KR',sans-serif;line-height:1.7;padding-bottom:80px}
  .lesson-header{background:#0a1628;padding:36px 24px 32px;text-align:center}.gbc-badge{display:inline-block;border:1px solid rgba(0,242,255,0.5);color:rgba(0,242,255,0.8);font-family:'Poppins',sans-serif;font-size:11px;letter-spacing:2px;padding:4px 14px;border-radius:20px;margin-bottom:16px}.lesson-num-title{font-family:'Poppins',sans-serif;font-size:15px;font-weight:400;color:rgba(255,255,255,0.6);margin-bottom:6px}.lesson-main-title{font-family:'Cormorant Garamond',serif;font-style:italic;font-size:44px;font-weight:500;color:#00f2ff;line-height:1.15;margin-bottom:10px}.lesson-sub{font-size:14px;color:rgba(255,255,255,0.5)}
  .toc{background:var(--green-dark);padding:12px 20px;display:flex;gap:8px;flex-wrap:wrap;justify-content:center}.toc a{font-size:12px;padding:4px 12px;border-radius:20px;border:1px solid rgba(255,255,255,0.2);color:rgba(255,255,255,0.75);text-decoration:none}.toc a:hover{background:rgba(255,255,255,0.1);color:#fff}
  .content{max-width:740px;margin:0 auto;padding:0 20px}
  .section{margin-top:28px;background:var(--white);border-radius:16px;overflow:hidden;border:1px solid var(--border)}.section-header{display:flex;align-items:center;gap:12px;padding:14px 20px;border-bottom:1px solid var(--border)}.section-num{width:28px;height:28px;border-radius:8px;display:flex;align-items:center;justify-content:center;font-family:'Poppins',sans-serif;font-size:13px;font-weight:700;flex-shrink:0;color:#fff}.section-title{font-size:15px;font-weight:700;color:var(--text)}.section-en{font-size:11px;color:var(--muted);font-family:'Poppins',sans-serif;letter-spacing:1px;margin-left:6px}.section-body{padding:20px}
  .key-card{background:var(--green-card);border-radius:12px;padding:20px;margin-bottom:16px}.key-label{font-size:11px;font-family:'Poppins',sans-serif;letter-spacing:2px;color:var(--gold);margin-bottom:10px}.key-text{font-family:'Cormorant Garamond',serif;font-style:italic;font-size:30px;font-weight:500;color:#fff;margin-bottom:6px}.key-kr{font-size:13px;color:rgba(255,255,255,0.65)}
  .concept-box{background:var(--green-light);border-radius:10px;padding:16px;margin-bottom:12px;border-left:4px solid var(--green-mid)}.concept-box p{font-size:14px;margin-bottom:8px}.concept-box p:last-child{margin-bottom:0}
  .rule-grid{display:grid;grid-template-columns:1fr 1fr;gap:10px;margin-bottom:14px}.rule-card{padding:14px 16px;border-radius:12px;border:1px solid var(--border)}.rule-label{font-size:10px;font-family:'Poppins',sans-serif;letter-spacing:1.5px;font-weight:700;margin-bottom:8px}.rule-example{font-family:'Poppins',sans-serif;font-size:13px}.rule-example strong{font-weight:700}.r-is{background:var(--green-light);border-color:#b8d4b0}.r-is .rule-label{color:var(--green-dark)}.r-is .rule-example strong{color:var(--green-dark)}.r-are{background:#e8f4e8;border-color:#a8ccaa}.r-are .rule-label{color:#3a6640}.r-are .rule-example strong{color:#3a6640}.r-neg{background:#fdf0e0;border-color:#e8c88a}.r-neg .rule-label{color:#8a5a1a}.r-neg .rule-example strong{color:#8a5a1a}.r-q{background:var(--brown-light);border-color:#d4c0a0}.r-q .rule-label{color:var(--brown)}.r-q .rule-example strong{color:var(--brown)}
  .rule-list{list-style:none;display:flex;flex-direction:column;gap:6px}.rule-list li{font-size:14px;padding:8px 12px;background:var(--cream);border-radius:8px;border-left:3px solid var(--green-mid)}.rule-list li strong{color:var(--green-dark);font-family:'Poppins',sans-serif}
  .ex-list{list-style:none;display:flex;flex-direction:column;gap:8px}.ex-list li{padding:12px 16px;background:var(--cream);border-radius:10px;border-left:4px solid var(--green-mid);font-size:14px}.ex-list li .en{color:var(--green-dark);font-weight:700;font-family:'Poppins',sans-serif}.ex-list li .kr{color:var(--muted);font-size:12px;display:block;margin-top:2px}.ex-q{border-left-color:var(--brown)!important}.ex-q .en{color:var(--brown)!important}
  .dialogue{background:var(--cream);border-radius:12px;padding:16px;margin-bottom:10px;border:1px solid var(--border)}.d-title{font-size:10px;font-family:'Poppins',sans-serif;letter-spacing:1.5px;color:var(--gold);font-weight:700;margin-bottom:10px}.d-line{font-size:14px;margin-bottom:5px}.d-line .sp{color:var(--green-dark);font-weight:700;margin-right:6px}.d-line .key{color:var(--green-dark);font-weight:700;font-family:'Poppins',sans-serif}
  .practice-item{padding:12px 16px;border-radius:10px;border:1px solid var(--border);margin-bottom:8px;font-size:14px;background:var(--cream)}.practice-item .original{color:var(--muted);margin-bottom:4px;font-size:13px}.practice-item .result{color:var(--green-dark);font-weight:700;font-family:'Poppins',sans-serif}
  .pattern-box{background:var(--gold-light);border:1px solid #e8c88a;border-radius:10px;padding:14px 16px;margin-bottom:8px}.pattern-box .p-label{font-size:11px;color:var(--gold);font-family:'Poppins',sans-serif;letter-spacing:1px;font-weight:700;margin-bottom:6px}.pattern-box .p-text{font-size:14px;color:var(--brown)}.pattern-box .p-text strong{color:#7a5010;font-family:'Poppins',sans-serif}
  .mistake-box{background:#fff5f5;border:1px solid #f4c0c0;border-radius:10px;padding:14px 16px;margin-bottom:8px}.mistake-box .wrong{color:#c0392b;font-size:13px;text-decoration:line-through;margin-bottom:4px}.mistake-box .right{color:var(--green-dark);font-size:14px;font-weight:700;font-family:'Poppins',sans-serif}.mistake-box .reason{color:var(--muted);font-size:12px;margin-top:4px}
  .tip-box{background:#e8f0ff;border:1px solid #b8c8f0;border-radius:10px;padding:14px 16px;margin-bottom:8px}.tip-box .tip-label{font-size:11px;color:#3050a0;font-family:'Poppins',sans-serif;letter-spacing:1px;font-weight:700;margin-bottom:6px}.tip-box .tip-text{font-size:14px;color:#1a2a60}
  .checklist{list-style:none;display:flex;flex-direction:column;gap:8px}.checklist li{display:flex;align-items:center;gap:12px;font-size:14px;padding:10px 14px;background:var(--cream);border-radius:10px;cursor:pointer}.chk{width:20px;height:20px;border:2px solid var(--green-mid);border-radius:6px;flex-shrink:0;display:flex;align-items:center;justify-content:center;transition:all 0.2s;background:#fff}.chk.on{background:var(--green-mid);border-color:var(--green-dark)}.chk.on::after{content:'✓';color:#fff;font-size:12px;font-weight:700}
  .footer-nav{background:var(--green-dark);display:flex;justify-content:space-between;align-items:center;padding:14px 24px;margin-top:32px}.fnav-btn{padding:8px 20px;border-radius:20px;font-size:13px;font-weight:700;cursor:pointer;text-decoration:none;border:none;font-family:'Poppins',sans-serif}.fnav-prev{background:rgba(255,255,255,0.15);color:#fff}.fnav-center{color:rgba(255,255,255,0.6);font-size:12px;letter-spacing:1px;font-family:'Poppins',sans-serif}.fnav-next{background:var(--gold);color:#000}
</style>
</head>
<body data-grammar-id="G67">

<div class="lesson-header">
  <div class="gbc-badge">CEC GRAMMAR BASECAMP</div>
  <div class="lesson-num-title">G67 · Advanced Grammar</div>
  <div class="lesson-main-title">Modals of Deduction</div>
  <div class="lesson-sub">추론 조동사 — must have, can't have</div>
</div>

<div class="toc">
  <a href="#concept">기본 개념</a> <a href="#grammar">문법 규칙</a> <a href="#positive">긍정문</a> <a href="#question">의문문</a> <a href="#dialogue">대화 흐름</a> <a href="#combining">문장 결합</a> <a href="#reallife">실생활</a> <a href="#patterns">패턴</a> <a href="#mistakes">흔한 실수</a> <a href="#tips">레벨업 팁</a> <a href="#practice">연습문제</a> <a href="#check">자가진단</a>
</div>

<div class="content">

  <div class="section" id="s1">
    <div class="section-header"><div class="section-num" style="background:var(--green-dark);">1</div><div><span class="section-title">기본 개념</span><span class="section-en">BASIC CONCEPT</span></div></div>
    <div class="section-body">
      <div class="key-card"><div class="key-label">⭐ TODAY'S KEY GRAMMAR</div><div class="key-text">Modals of Deduction</div><div class="key-kr">과거 상황에 대한 확신 또는 부정 추측을 표현하는 구조</div></div>
      <div class="concept-box">
        <p><strong style="color:var(--green-dark)">must have + p.p.</strong> → 분명 ~했을 거야 (강한 확신, 90% 이상)</p>
        <p><strong style="color:#3a6640">can't have + p.p.</strong> → 절대 ~하지 않았을 거야 (강한 부정, 거의 0%)</p>
        <p>논리적 단서나 정황을 바탕으로 과거를 추론합니다.</p>
      </div>
      <ul class="ex-list">
        <li><span class="en">He must have left early.</span> (불이 꺼져 있어)<span class="kr">그는 분명 일찍 떠났을 거야.</span></li>
        <li><span class="en">She can't have forgotten.</span> (메모를 했으니까)<span class="kr">그녀가 잊었을 리가 없어.</span></li>
      </ul>
    </div>
  </div>

  <div class="section" id="s2">
    <div class="section-header"><div class="section-num" style="background:#3a6640;">2</div><div><span class="section-title">문법 규칙</span><span class="section-en">GRAMMAR RULES</span></div></div>
    <div class="section-body">
      <div class="rule-grid">
        <div class="rule-card r-is"><div class="rule-label">강한 확신 · MUST HAVE</div><div class="rule-example"><strong>must have + p.p.</strong><br><span style="font-size:12px;color:var(--muted)">He must have left.</span></div></div>
        <div class="rule-card r-are"><div class="rule-label">강한 부정 · CAN'T HAVE</div><div class="rule-example"><strong>can't have + p.p.</strong><br><span style="font-size:12px;color:var(--muted)">She can't have forgotten.</span></div></div>
        <div class="rule-card r-neg"><div class="rule-label">과거 추론 · PAST ONLY</div><div class="rule-example">시제는 항상 <strong>과거</strong><br><span style="font-size:12px;color:var(--muted)">논리적 단서 기반</span></div></div>
        <div class="rule-card r-q"><div class="rule-label">진술문 위주 · STATEMENTS</div><div class="rule-example">의문문에서는 거의 불사용<br><span style="font-size:12px;color:var(--muted)">주로 진술문에서 사용</span></div></div>
      </div>
      <ul class="rule-list">
        <li><strong>기본 구조:</strong> 주어 + must/can't + have + 과거분사(p.p.)</li>
        <li><strong>must have + p.p.</strong> → 과거에 분명히 일어난 일에 대한 확신</li>
        <li><strong>can't have + p.p.</strong> → 과거에 일어나지 않았을 것이라는 강한 부정</li>
        <li><strong>논리적 단서</strong>나 정황을 바탕으로 사용</li>
        <li><strong>구어체와 글쓰기</strong> 모두에서 사용 가능</li>
      </ul>
    </div>
  </div>

  <div class="section" id="s3">
    <div class="section-header"><div class="section-num" style="background:var(--gold); color:#000;">3</div><div><span class="section-title">긍정문 예시</span><span class="section-en">POSITIVE EXAMPLES</span></div></div>
    <div class="section-body">
      <ul class="ex-list">
        <li><span class="en">He must have left early.</span><span class="kr">불이 꺼져 있어 — 분명 일찍 떠났을 거야.</span></li>
        <li><span class="en">She must have studied hard.</span><span class="kr">시험을 잘 봤어 — 분명 열심히 공부했을 거야.</span></li>
        <li><span class="en">They must have arrived by now.</span><span class="kr">길이 막히지 않았어 — 지금쯤 도착했을 거야.</span></li>
        <li><span class="en">You must have been tired.</span><span class="kr">늦게까지 일했잖아 — 분명 피곤했을 거야.</span></li>
        <li><span class="en">He must have forgotten his keys.</span><span class="kr">문 앞에 서 있어 — 열쇠를 잊었나 봐.</span></li>
        <li><span class="en">He can't have forgotten the meeting.</span><span class="kr">캘린더에 적혀 있어 — 잊었을 리가 없어.</span></li>
        <li><span class="en">She can't have gone home.</span><span class="kr">가방이 여기 있어 — 집에 갔을 리가 없어.</span></li>
        <li><span class="en">They can't have finished already.</span><span class="kr">너무 빨라 — 벌써 끝났을 리가 없어.</span></li>
        <li><span class="en">You can't have seen him.</span><span class="kr">그는 해외에 있어 — 그를 봤을 리가 없어.</span></li>
        <li><span class="en">We can't have made that mistake.</span><span class="kr">다시 확인했어 — 그런 실수를 했을 리가 없어.</span></li>
      </ul>
    </div>
  </div>

  <div class="section" id="s4">
    <div class="section-header"><div class="section-num" style="background:var(--brown);">4</div><div><span class="section-title">의문문 예시</span><span class="section-en">QUESTION EXAMPLES</span></div></div>
    <div class="section-body">
      <ul class="ex-list">
        <li class="ex-q"><span class="en">Why do we say "must have gone" instead of "must went"?</span><span class="kr">왜 "must went"가 아니라 "must have gone"이라고 하나요?</span></li>
        <li class="ex-q"><span class="en">Can you explain "can't have seen him"?</span><span class="kr">"can't have seen him"을 설명해 줄 수 있나요?</span></li>
        <li class="ex-q"><span class="en">What does "must have been tired" mean?</span><span class="kr">"must have been tired"는 무슨 뜻인가요?</span></li>
        <li class="ex-q"><span class="en">What clues help us use modals of deduction?</span><span class="kr">추론 조동사를 사용하는 데 어떤 단서가 도움이 되나요?</span></li>
        <li class="ex-q"><span class="en">What's the difference between "must have" and "might have"?</span><span class="kr">"must have"와 "might have"의 차이는?</span></li>
        <li class="ex-q"><span class="en">When do we use "can't have" instead of "didn't"?</span><span class="kr">언제 "didn't" 대신 "can't have"를 사용하나요?</span></li>
        <li class="ex-q"><span class="en">How certain are we when using "must have"?</span><span class="kr">"must have"를 사용할 때 얼마나 확신하나요?</span></li>
        <li class="ex-q"><span class="en">Can you show the difference between "must be" and "must have been"?</span><span class="kr">"must be"와 "must have been"의 차이를 보여줄 수 있나요?</span></li>
      </ul>
    </div>
  </div>

  <div class="section" id="s5">
    <div class="section-header"><div class="section-num" style="background:#5a7a50;">5</div><div><span class="section-title">상황별 대화 흐름</span><span class="section-en">SITUATIONAL DIALOGUES</span></div></div>
    <div class="section-body">
      <div class="dialogue"><div class="d-title">🏫 학교 상황 · SCHOOL</div><div class="d-line"><span class="sp">A:</span> She got full marks again.</div><div class="d-line"><span class="sp">B:</span> She <span class="key">must have studied</span> a lot.</div><div class="d-line"><span class="sp">A:</span> Definitely, her dedication shows.</div></div>
      <div class="dialogue"><div class="d-title">✈️ 여행 상황 · TRAVEL</div><div class="d-line"><span class="sp">A:</span> They're not at the train station.</div><div class="d-line"><span class="sp">B:</span> They <span class="key">must have taken</span> a taxi instead.</div><div class="d-line"><span class="sp">A:</span> That makes perfect sense.</div></div>
      <div class="dialogue"><div class="d-title">💼 직장 상황 · OFFICE</div><div class="d-line"><span class="sp">A:</span> He didn't reply to my email.</div><div class="d-line"><span class="sp">B:</span> He <span class="key">must have missed</span> it somehow.</div><div class="d-line"><span class="sp">A:</span> I'll resend it with high priority.</div></div>
      <div class="dialogue"><div class="d-title">💻 온라인 상황 · ONLINE</div><div class="d-line"><span class="sp">A:</span> She posted that at 3 a.m.</div><div class="d-line"><span class="sp">B:</span> She <span class="key">must have stayed</span> up all night.</div><div class="d-line"><span class="sp">A:</span> That's dedication to her work.</div></div>
      <div class="dialogue"><div class="d-title">🏠 가족 상황 · FAMILY</div><div class="d-line"><span class="sp">A:</span> Dad's shoes are missing from the entrance.</div><div class="d-line"><span class="sp">B:</span> He <span class="key">must have gone</span> for his morning walk.</div><div class="d-line"><span class="sp">A:</span> Let's wait for him to come back.</div></div>
      <div class="dialogue"><div class="d-title">🏥 병원 상황 · HOSPITAL</div><div class="d-line"><span class="sp">A:</span> She's not in her hospital room.</div><div class="d-line"><span class="sp">B:</span> She <span class="key">can't have left</span> without permission.</div><div class="d-line"><span class="sp">A:</span> Let's check with the nurse's station.</div></div>
    </div>
  </div>

  <div class="section" id="s6">
    <div class="section-header"><div class="section-num" style="background:var(--green-dark);">6</div><div><span class="section-title">문장 결합 연습</span><span class="section-en">SENTENCE COMBINING</span></div></div>
    <div class="section-body">
      <div class="practice-item"><div class="original">I'm sure he left early.</div><div class="result">→ He must have left early.</div></div>
      <div class="practice-item"><div class="original">I'm sure she studied hard.</div><div class="result">→ She must have studied hard.</div></div>
      <div class="practice-item"><div class="original">I'm sure they arrived.</div><div class="result">→ They must have arrived.</div></div>
      <div class="practice-item"><div class="original">I'm sure you were tired.</div><div class="result">→ You must have been tired.</div></div>
      <div class="practice-item"><div class="original">It's impossible he forgot.</div><div class="result">→ He can't have forgotten.</div></div>
      <div class="practice-item"><div class="original">It's impossible she went home.</div><div class="result">→ She can't have gone home.</div></div>
      <div class="practice-item"><div class="original">It's impossible they finished.</div><div class="result">→ They can't have finished.</div></div>
      <div class="practice-item"><div class="original">It's impossible you saw him.</div><div class="result">→ You can't have seen him.</div></div>
      <div class="practice-item"><div class="original">It's impossible we made that mistake.</div><div class="result">→ We can't have made that mistake.</div></div>
    </div>
  </div>

  <div class="section" id="s7">
    <div class="section-header"><div class="section-num" style="background:var(--gold); color:#000;">7</div><div><span class="section-title">실생활 사용 예시</span><span class="section-en">REAL-LIFE USAGE</span></div></div>
    <div class="section-body">
      <ul class="ex-list">
        <li><span class="en">She must have studied all night.</span><span class="kr">🏫 학교 — 밤새 공부했나 봐.</span></li>
        <li><span class="en">He must have missed the email.</span><span class="kr">💼 직장 — 이메일을 놓쳤나 봐.</span></li>
        <li><span class="en">They must have taken a taxi.</span><span class="kr">✈️ 여행 — 택시를 탔나 봐.</span></li>
        <li><span class="en">He must have gone for a walk.</span><span class="kr">🏠 가족 — 산책 갔나 봐.</span></li>
        <li><span class="en">She can't have left without permission.</span><span class="kr">🏥 병원 — 허락 없이 갔을 리가 없어.</span></li>
        <li><span class="en">They must have had a big sale.</span><span class="kr">🛒 쇼핑 — 큰 세일이 있었나 봐.</span></li>
        <li><span class="en">He can't have forgotten about the party.</span><span class="kr">🎉 파티 — 파티를 잊었을 리가 없어.</span></li>
      </ul>
    </div>
  </div>

  <div class="section" id="s8">
    <div class="section-header"><div class="section-num" style="background:var(--brown);">8</div><div><span class="section-title">자주 쓰이는 패턴</span><span class="section-en">COMMON PATTERNS</span></div></div>
    <div class="section-body">
      <div class="pattern-box"><div class="p-label">강한 확신 · MUST HAVE + P.P.</div><div class="p-text"><strong>He must have left</strong> early.<br><span style="font-size:13px;">단서: 불이 꺼져 있어 → 분명 떠났을 거야</span></div></div>
      <div class="pattern-box"><div class="p-label">강한 부정 · CAN'T HAVE + P.P.</div><div class="p-text"><strong>She can't have forgotten.</strong><br><span style="font-size:13px;">단서: 메모를 했어 → 잊었을 리가 없어</span></div></div>
      <div class="pattern-box"><div class="p-label">상태 추론 · MUST HAVE BEEN</div><div class="p-text"><strong>You must have been tired.</strong><br><span style="font-size:13px;">단서: 늦게까지 일했어 → 분명 피곤했을 거야</span></div></div>
      <div class="pattern-box"><div class="p-label">불가능 추론 · CAN'T HAVE BEEN</div><div class="p-text"><strong>We can't have been wrong.</strong><br><span style="font-size:13px;">단서: 증거가 명확해 → 틀렸을 리가 없어</span></div></div>
    </div>
  </div>

  <div class="section" id="s9">
    <div class="section-header"><div class="section-num" style="background:#c0392b;">9</div><div><span class="section-title">흔한 실수</span><span class="section-en">COMMON MISTAKES</span></div></div>
    <div class="section-body">
      <div class="mistake-box"><div class="wrong">✗ He must went home.</div><div class="right">✓ He must have gone home.</div><div class="reason">must 뒤에 have + p.p. 구조 필수</div></div>
      <div class="mistake-box"><div class="wrong">✗ She can't forgot.</div><div class="right">✓ She can't have forgotten.</div><div class="reason">can't 뒤에 have + p.p. 구조 필수</div></div>
      <div class="mistake-box"><div class="wrong">✗ They must have arrive.</div><div class="right">✓ They must have arrived.</div><div class="reason">have 뒤에 과거분사(p.p.) 필수</div></div>
      <div class="mistake-box"><div class="wrong">✗ He must been tired.</div><div class="right">✓ He must have been tired.</div><div class="reason">must와 been 사이에 have 필수</div></div>
    </div>
  </div>

  <div class="section" id="s10">
    <div class="section-header"><div class="section-num" style="background:#185fa5;">10</div><div><span class="section-title">레벨업 팁</span><span class="section-en">LEVEL-UP TIPS</span></div></div>
    <div class="section-body">
      <div class="tip-box"><div class="tip-label">TIP 1 · 단서 찾기</div><div class="tip-text">추론 조동사를 사용하려면 논리적 단서가 필요합니다. "불이 꺼져 있어" → must have left</div></div>
      <div class="tip-box"><div class="tip-label">TIP 2 · must have vs might have</div><div class="tip-text">must have는 90% 이상 확신, might have는 50% 정도 추측입니다.</div></div>
      <div class="tip-box"><div class="tip-label">TIP 3 · 현재 vs 과거</div><div class="tip-text">must be = 현재 추론 ("He must be tired"), must have been = 과거 추론 ("He must have been tired")</div></div>
      <div class="tip-box"><div class="tip-label">TIP 4 · 미스터리 풀기</div><div class="tip-text">추리 소설이나 뉴스에서 자주 등장합니다. 일상에서도 단서를 보고 추론하는 연습을 해보세요.</div></div>
    </div>
  </div>

  <div class="section" id="s11">
    <div class="section-header"><div class="section-num" style="background:var(--green-dark);">11</div><div><span class="section-title">연습문제</span><span class="section-en">PRACTICE EXERCISES</span></div></div>
    <div class="section-body">
      <p style="font-size:13px; color:var(--muted); margin-bottom:14px;">빈칸에 must have 또는 can't have를 넣어 문장을 완성하세요.</p>
      <ul class="rule-list">
        <li>He ___ left early. (불이 꺼져 있어) <strong style="color:var(--green-dark)">(must have)</strong></li>
        <li>She ___ forgotten. (메모를 했어) <strong style="color:var(--brown)">(can't have)</strong></li>
        <li>They ___ arrived by now. <strong style="color:var(--green-dark)">(must have)</strong></li>
        <li>You ___ seen him. (그는 해외에 있어) <strong style="color:var(--brown)">(can't have)</strong></li>
        <li>She ___ studied hard. (만점이야) <strong style="color:var(--green-dark)">(must have)</strong></li>
        <li>He ___ gone home. (가방이 여기 있어) <strong style="color:var(--brown)">(can't have)</strong></li>
        <li>We ___ missed the bus. (정류장에 아무도 없어) <strong style="color:var(--green-dark)">(must have)</strong></li>
        <li>They ___ finished already. (너무 빨라) <strong style="color:var(--brown)">(can't have)</strong></li>
      </ul>
    </div>
  </div>

  <div class="section" id="s11">
    <div class="section-header"><div class="section-num" style="background:var(--brown);">12</div><div><span class="section-title">자가진단 체크리스트</span><span class="section-en">SELF-CHECK</span></div></div>
    <div class="section-body">
      <ul class="checklist">
        <li onclick="this.querySelector('.chk').classList.toggle('on')"><div class="chk"></div> must have + p.p.가 강한 확신임을 안다.</li>
        <li onclick="this.querySelector('.chk').classList.toggle('on')"><div class="chk"></div> can't have + p.p.가 강한 부정 추측임을 안다.</li>
        <li onclick="this.querySelector('.chk').classList.toggle('on')"><div class="chk"></div> 논리적 단서를 바탕으로 추론 문장을 만들 수 있다.</li>
        <li onclick="this.querySelector('.chk').classList.toggle('on')"><div class="chk"></div> must be(현재)와 must have been(과거)의 차이를 안다.</li>
        <li onclick="this.querySelector('.chk').classList.toggle('on')"><div class="chk"></div> must have와 might have의 확신도 차이를 안다.</li>
        <li onclick="this.querySelector('.chk').classList.toggle('on')"><div class="chk"></div> 일상 대화에서 추론 표현을 자연스럽게 사용할 수 있다.</li>
        <li onclick="this.querySelector('.chk').classList.toggle('on')"><div class="chk"></div> 흔한 실수 4가지를 이해했다.</li>
      </ul>
    </div>
  </div>

</div>

<div class="footer-nav">
  <a href="G66_new.html" class="fnav-btn fnav-prev">← G66</a>
  <span class="fnav-center">G67 · MODALS OF DEDUCTION</span>
  <a href="G68_new.html" class="fnav-btn fnav-next">G68 →</a>
</div>



<style>
.gb{position:fixed;bottom:24px;right:24px;z-index:9999;display:flex;flex-direction:column;align-items:flex-end;gap:8px;}
.gb-hint{background:#4a6741;color:#fff;font-size:12px;padding:7px 14px;border-radius:20px 20px 4px 20px;cursor:pointer;white-space:nowrap;animation:gbFloat 3s ease-in-out infinite;font-family:sans-serif;}
.gb-hint span{color:#c8e6a0;}
@keyframes gbFloat{0%,100%{transform:translateY(0);}50%{transform:translateY(-4px);}}
.gb-robo{width:56px;height:56px;border-radius:50%;background:#4a6741;border:2px solid #a8d070;cursor:pointer;overflow:hidden;display:flex;align-items:center;justify-content:center;}
.gb-robo img{width:46px;height:46px;object-fit:cover;border-radius:50%;}
.gb-panel{display:none;position:fixed;bottom:92px;right:24px;width:300px;background:#fff;border-radius:20px;border:0.5px solid #c8d8b8;box-shadow:0 4px 24px rgba(74,103,65,0.15);overflow:hidden;z-index:9998;}
.gb-head{background:#4a6741;padding:12px 16px;display:flex;align-items:center;gap:10px;}
.gb-head img{width:28px;height:28px;border-radius:50%;object-fit:cover;}
.gb-ht{font-size:13px;font-weight:700;color:#fff;font-family:sans-serif;}
.gb-hs{font-size:11px;color:#c8e6a0;font-family:sans-serif;}
.gb-close{margin-left:auto;background:none;border:none;color:#a0c080;font-size:14px;cursor:pointer;}
.gb-chat{padding:12px 14px;height:180px;overflow-y:auto;display:flex;flex-direction:column;gap:8px;background:#f8faf5;}
.gb-ai-msg{display:flex;gap:8px;align-items:flex-start;}
.gb-ai-msg img{width:22px;height:22px;border-radius:50%;object-fit:cover;flex-shrink:0;}
.gb-ai-bubble{background:#fff;border:0.5px solid #c8d8b8;border-radius:0 10px 10px 10px;padding:8px 12px;font-size:12px;color:#2d4a25;line-height:1.6;max-width:210px;white-space:pre-line;font-family:sans-serif;}
.gb-user-msg{display:flex;justify-content:flex-end;}
.gb-user-bubble{background:#4a6741;color:#fff;border-radius:10px 0 10px 10px;padding:8px 12px;font-size:12px;max-width:200px;line-height:1.5;white-space:pre-line;font-family:sans-serif;}
.gb-input-row{padding:10px 12px;border-top:0.5px solid #d0e0c0;display:flex;gap:8px;background:#fff;}
.gb-input{flex:1;padding:8px 12px;border-radius:20px;border:0.5px solid #c0d0b0;font-size:12px;font-family:sans-serif;outline:none;background:#f8faf5;}
.gb-send{width:34px;height:34px;border-radius:50%;background:#4a6741;border:none;cursor:pointer;color:#fff;font-size:14px;flex-shrink:0;}
.gb-btns{padding:10px 12px 12px;display:flex;gap:8px;background:#fff;}
.gb-btn1{flex:1;padding:9px;background:#4a6741;color:#fff;border:none;border-radius:10px;font-size:12px;font-weight:700;cursor:pointer;font-family:sans-serif;}
.gb-btn2{flex:1;padding:9px;background:#f0f8e8;border:0.5px solid #a8d070;color:#4a6741;border-radius:10px;font-size:12px;font-weight:700;cursor:pointer;font-family:sans-serif;}
</style>
<div class="gb">
  <div class="gb-hint" onclick="gbToggle()" id="gbHint">
    <span id="gbHintText">문법</span> 질문 있으세요?
  </div>
  <div class="gb-robo" onclick="gbToggle()">
    <img src="../robo_jump.gif" alt="Robo" onerror="this.src='https://pub-a418b5aad0bd4c3fb41cf7159403fc12.r2.dev/robo_jump.gif'">
  </div>
</div>
<div class="gb-panel" id="gbPanel">
  <div class="gb-head">
    <img src="../robo_jump.gif" alt="Robo" onerror="this.src='https://pub-a418b5aad0bd4c3fb41cf7159403fc12.r2.dev/robo_jump.gif'">
    <div>
      <div class="gb-ht">Grammar AI 선생님</div>
      <div class="gb-hs" id="gbSub">문법 설명 + 회화 연결</div>
    </div>
    <button class="gb-close" onclick="gbToggle()">&#10005;</button>
  </div>
  <div class="gb-chat" id="gbChat">
    <div class="gb-ai-msg">
      <img src="../robo_jump.gif" onerror="this.src='https://pub-a418b5aad0bd4c3fb41cf7159403fc12.r2.dev/robo_jump.gif'">
      <div class="gb-ai-bubble">안녕하세요! 👋 궁금한 문법 뭐든 물어보세요!</div>
    </div>
  </div>
  <div class="gb-input-row">
    <input class="gb-input" id="gbInput" type="text" placeholder="질문을 입력하세요..." onkeydown="if(event.key==='Enter')gbSend()">
    <button class="gb-send" onclick="gbSend()">→</button>
  </div>
  <div class="gb-btns">
    <button class="gb-btn1" onclick="gbAsk()">💬 Open WebUI 열기</button>
    <button class="gb-btn2" onclick="gbCamp()">🏕️ 캠프 보기</button>
  </div>
</div>
<script src="../grammar_story_map.js"></script>
<script>
(function(){
  var path=window.location.pathname;
  var m=path.match(/G(\d+)/i);
  var gid=m?'G'+('0'+m[1]).slice(-2):'G01';
  var data=(typeof GRAMMAR_STORY_MAP!=='undefined')?GRAMMAR_STORY_MAP[gid]:null;
  if(data){
    document.getElementById('gbHintText').textContent=data.title;
    document.getElementById('gbSub').textContent=gid+' — '+data.title;
    gbAddAI('안녕하세요! 👋\n'+data.title+' 궁금한 거 물어보세요!\n예: '+data.example);
  }
  var gbOpen=false;
  window.gbToggle=function(){
    gbOpen=!gbOpen;
    document.getElementById('gbPanel').style.display=gbOpen?'block':'none';
    document.getElementById('gbHint').style.opacity=gbOpen?'0':'1';
    if(gbOpen)setTimeout(function(){document.getElementById('gbInput').focus();},100);
  };
  window.gbSend=function(){
    var inp=document.getElementById('gbInput');
    var msg=inp.value.trim();
    if(!msg)return;
    gbAddUser(msg);
    inp.value='';
    setTimeout(function(){gbAddAI('좋은 질문이에요!\nOpen WebUI에서 더 자세히 답해드릴게요 😊');},500);
  };
  window.gbAsk=function(){
    var prompt=data?data.prompt:'문법 질문이 있어요!';
    navigator.clipboard.writeText(prompt).catch(function(){});
    window.open('http://localhost:3001/?models=cec_grammar','_blank');
  };
  window.gbCamp=function(){
    window.open('https://cecenglishcamp.github.io/','_blank');
  };
  window.gbAddAI=function(msg){
    var c=document.getElementById('gbChat');
    var d=document.createElement('div');
    d.className='gb-ai-msg';
    d.innerHTML='<img src="../robo_jump.gif" onerror="this.src=\'https://pub-a418b5aad0bd4c3fb41cf7159403fc12.r2.dev/robo_jump.gif\'">'
      +'<div class="gb-ai-bubble">'+msg+'</div>';
    c.appendChild(d);c.scrollTop=c.scrollHeight;
  };
  window.gbAddUser=function(msg){
    var c=document.getElementById('gbChat');
    var d=document.createElement('div');
    d.className='gb-user-msg';
    d.innerHTML='<div class="gb-user-bubble">'+msg+'</div>';
    c.appendChild(d);c.scrollTop=c.scrollHeight;
  };
  setTimeout(function(){
    var h=document.getElementById('gbHint');
    if(h){h.style.background='#a8d070';h.style.color='#2d4a25';
      setTimeout(function(){h.style.background='#4a6741';h.style.color='#fff';},2000);}
  },5000);
})();
</script>
</body>
</html>
